# MainstreamOS [mainstream] repo — package build list (single source of truth).
#
# Format: one entry per line.
#   <pkgname>              AUR git repo name == package name
#   <pkgname>::<pkgbase>   AUR git repo (pkgbase) differs from the package name
# Blank lines and #-comments are ignored.
#
# Every entry here is FOSS and verified against the AUR. Proprietary or
# non-redistributable packages must NOT be added (e.g. ttf-google-sans /
# Google Sans is proprietary; DaVinci Resolve, Plex). FOSS only.

# ── Default apps (Nautilus extensions + mpv scripts) ──
nautilus-copy-path
nautilus-admin-gtk4
mpv-modernz
mpv-thumbfast-git

# ── Browser ──
zen-browser-bin

# ── Fonts / themes ──
adw-gtk-theme-git
otf-space-grotesk::local
ttf-material-symbols-variable-git::material-symbols-git
ttf-readex-pro
ttf-rubik-vf
ttf-twemoji
breeze-plus
darkly-bin

# ── Widgets / tools ──
wlogout
topgrade
qt6-avif-image-plugin::qt5-avif-image-plugin

# ── Optional limine + snapper integration (setup-limine-snapper.sh) ──
limine-mkinitcpio-hook
limine-snapper-sync

# ── System / build deps ──
ckbcomp
cpptrace
